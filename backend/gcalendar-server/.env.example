# Google Calendar MCP Server Configuration
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
# Enable API: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8083/auth/g-calender/callback

# Server
PORT=8083
NODE_ENV=development
TOKEN_PATH=./token.json

# Redis (required for HTTP mode)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-character-hex-encryption-key
ALLOWED_REDIRECT_URIS=http://localhost:9000,http://localhost:9000/,http://localhost:3000,http://localhost:3000/
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://localhost:3000

# Logging & Monitoring
LOG_LEVEL=info
METRICS_AUTH_TOKEN=

# Session
SESSION_CLEANUP_ENABLED=true
SESSION_CLEANUP_SCHEDULE=0 * * * *
COOKIE_DOMAIN=

# AWS Secrets Manager (optional, production only)
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=gcalendar-mcp/encryption-key
