{
  "name": "@neurix/server-core",
  "version": "0.1.0",
  "description": "Shared HTTP/OAuth/session infrastructure for Neurix MCP servers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
