{
  "name": "neurix",
  "version": "1.0.0",
  "private": true,
  "description": "Neurix - Enterprise MCP Chat Interface Platform",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build:sdk": "pnpm --filter @neurix/mcp-sdk build",
    "build:core": "pnpm --filter @neurix/server-core build",
    "build:backend": "pnpm build:sdk && pnpm build:core && pnpm --filter @neurix/gateway build",
    "build:frontend": "pnpm --filter @neurix/frontend build",
    "build:all": "pnpm build:backend && pnpm build:frontend",
    "dev:backend": "pnpm --filter @neurix/gateway start",
    "dev:frontend": "pnpm --filter @neurix/frontend dev",
    "start:backend": "pnpm --filter @neurix/gateway start",
    "start:frontend": "pnpm --filter @neurix/frontend preview",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-workspace",
    "ai-assistant",
    "chat-interface"
  ],
  "author": "",
  "license": "MIT"
}
